# Carding environment. Copy to .env.local (gitignored) and fill in.
# Conductor copies .env.local into every new workspace (see .conductor/settings.toml).

# --- Supabase (manual prereq, see docs/BUILD-PLAN.md) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Anthropic (generation pipeline) ---
ANTHROPIC_API_KEY=

# --- Web Push (daily study reminders) ---
# Generate a keypair with:  pnpm gen:vapid
# The public key is sent to the browser; the private key must stay server-side.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# --- Reminder cron ---
# Shared secret the reminder cron checks (Authorization: Bearer <secret>, or ?key=<secret>).
# Set this to a long random string; the scheduler that calls /api/cron/reminders must send it.
CRON_SECRET=
